# Database
DATABASE_URL=postgres://openpriors:openpriors@localhost:5432/openpriors

# Server
BIND_ADDR=0.0.0.0:8080

# LLM providers (at least one required for /v1/judge)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional: default model for judgements
DEFAULT_MODEL=claude-sonnet-4-6

# Optional: signing key for judgement receipts (Ed25519 seed, hex)
# Generate with: openssl rand -hex 32
RECEIPT_SIGNING_KEY=
