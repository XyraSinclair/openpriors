# Database
DATABASE_URL=postgres://<db-user>:<db-password>@localhost:5432/openpriors
DATABASE_MAX_CONNECTIONS=20
DATABASE_ACQUIRE_TIMEOUT_SECS=10

# Server
BIND_ADDR=0.0.0.0:8080

# LLM provider (required)
OPENROUTER_API_KEY=

# Optional: default model for judgements
DEFAULT_MODEL=openai/gpt-5-mini

# Optional: explicit browser origins allowed for cross-origin API calls.
# Leave empty to disable CORS entirely.
CORS_ALLOWED_ORIGINS=

# Optional: expose judgement traces publicly.
# Defaults to false; set to true only if you intentionally want public reasoning pages.
PUBLIC_JUDGEMENTS=false

# Optional: auth endpoint rate limit tuning.
AUTH_RATE_LIMIT_MAX_ATTEMPTS=10
AUTH_RATE_LIMIT_WINDOW_SECS=300

# Optional: admin key for manual credit grants.
# Admin grants are localhost-only by default unless ADMIN_ALLOWED_IPS is set.
ADMIN_API_KEY=
ADMIN_ALLOWED_IPS=127.0.0.1,::1
